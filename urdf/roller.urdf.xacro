<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

	<xacro:macro
		name="roller_macro"
		params="parent name xyz rpy"
	>

		<link name="roller_${name}_rim_${parent}_link">
			<inertial>
				<mass value="0.00113845"/>
				<inertia
					ixx="2.53776e-08"
					ixy="0"
					ixz="0"
					iyy="2.53776e-08"
					iyz="0"
					izz="1.47666e-08"
				/>
			</inertial>
            
			<visual>
				<geometry>
					<mesh filename="package://diff/mesh/roller.stl"/>
				</geometry>
				<material name="roller_material">
					<color rgba="0.1 0.1 0.1 1"/>
				</material>
			</visual>

			<collision>
				<geometry>
					<mesh filename="package://diff/mesh/roller.stl"/>
				</geometry>
			</collision>
		</link>
		<gazebo reference="roller_${name}_rim_${parent}_link">
		    <mu1>1.0</mu1>  <!-- Ma sát trượt (1.0 = bám đường như cao su) -->
		    <mu2>1.0</mu2>  <!-- Ma sát ngang -->
		    <kp>1000000.0</kp> <!-- Độ cứng của bánh xe tránh lún -->
		    <kd>100.0</kd>     <!-- Độ đàn hồi -->
		</gazebo>

		<joint
			name="roller_${name}_rim_${parent}_joint"
			type="continuous"
		>
			<parent link="rim_${parent}_link"/>
			<child link="roller_${name}_rim_${parent}_link"/>
			<axis xyz="0 0 1"/>
			<origin
				xyz="${xyz}"
				rpy="${rpy}"
			/>
			<dynamics damping="0.0" friction="0.0"/>
		</joint>
		<gazebo reference="roller_${name}_rim_${parent}_link">
            <mu1>1.0</mu1>
            <mu2>1.0</mu2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
            <minDepth>0.001</minDepth>
            <material>Gazebo/DarkGrey</material>
        </gazebo>
	</xacro:macro>

</robot>
